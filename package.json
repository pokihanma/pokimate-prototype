{
  "name": "pokimate",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:desktop": "pnpm --filter @pokimate/desktop dev",
    "dev:mobile": "pnpm --filter @pokimate/mobile dev",
    "build:desktop": "pnpm --filter @pokimate/desktop build",
    "build:mobile": "pnpm --filter @pokimate/mobile build",
    "db:rebuild": "pnpm --filter @pokimate/db exec node scripts/build-base-db.js",
    "db:build-base": "pnpm --filter @pokimate/db run build-base-db"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
