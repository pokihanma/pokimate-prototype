{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.pokimate.app",
  "productName": "PokiMate",
  "version": "0.0.1",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "PokiMate",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/base.db"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "PokiMate — Personal life OS",
    "shortDescription": "PokiMate",
    "category": "Productivity"
  },
  "plugins": {}
}
